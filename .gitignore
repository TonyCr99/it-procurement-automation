# ============================================================
# IT Procurement Automation — Git Ignore
# ============================================================

# ------------------------------------------------------------
# Credentials — NEVER upload to GitHub
# ------------------------------------------------------------
.env

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
.Python
env/
venv/
.venv/

# ------------------------------------------------------------
# VS Code
# ------------------------------------------------------------
.vscode/

# ------------------------------------------------------------
# OS files
# ------------------------------------------------------------
.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Logs and temp files
# ------------------------------------------------------------
*.log
*.tmp

# ------------------------------------------------------------
# Data files — mock versions are safe to commit
# Real versions contain sensitive company data
# ------------------------------------------------------------
src/data/cost_centers.xlsx
src/data/*.xlsx
!src/data/cost_centers_mock.xlsx

# Debug scripts — temporary, never commit
debug_*.py