# ============================================================
# IT Procurement Automation — Environment Variables
# ============================================================
# 1. Copy this file and rename it to .env
# 2. Fill in your credentials
# 3. Never commit .env to GitHub


# ------------------------------------------------------------
# Mock mode
# ------------------------------------------------------------
# Set to false to connect to real instances
# Default: true (safe for development)
# ------------------------------------------------------------
JIRA_MOCK=true
NETSUITE_MOCK=true
ABASTEO_MOCK=true
# ------------------------------------------------------------
# Jira
# ------------------------------------------------------------
JIRA_URL=                    # https://yourcompany.atlassian.net
JIRA_USER=                   # your-email@company.com
JIRA_API_TOKEN=              # Generate at: id.atlassian.com/manage-profile/security/api-tokens

# ------------------------------------------------------------
# Netsuite
# ------------------------------------------------------------
NETSUITE_ACCOUNT_ID=         # Found in Setup > Company > Company Information
NETSUITE_CONSUMER_KEY=       # Generated in Netsuite integrations setup
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# ------------------------------------------------------------
# Abasteo
# ------------------------------------------------------------
ABASTEO_URL=                 # https://www.abasteo.com.mx
ABASTEO_USER=                # your-login-email
ABASTEO_PASSWORD=            # your-password

# ------------------------------------------------------------
# Notifications
# ------------------------------------------------------------
# Supported channels: email, slack, teams
# Set to true to enable each channel
# ------------------------------------------------------------
NOTIFY_EMAIL=true
NOTIFY_SLACK=false
NOTIFY_TEAMS=false

# Email
NOTIFY_EMAIL_SENDER=
#SMTP config
NOTIFY_EMAIL_PASSWORD=
NOTIFY_SMTP_HOST=smtp.gmail.com
NOTIFY_SMTP_PORT=587

# Mock mode
NOTIFY_MOCK=true

# Slack
SLACK_WEBHOOK_URL=

# Microsoft Teams
TEAMS_WEBHOOK_URL=

# ------------------------------------------------------------
# Finance
# ------------------------------------------------------------
FINANCE_TEAM_EMAIL=          # finance team distribution email